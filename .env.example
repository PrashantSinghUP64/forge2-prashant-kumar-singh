GROQ_API_KEY=your_groq_key_here

# Slack Bot Token (xoxb-...) — from api.slack.com/apps → OAuth & Permissions
SLACK_BOT_TOKEN=xoxb-your-bot-token-here

# Slack App Token (xapp-...) — from api.slack.com/apps → Basic Information → App-Level Tokens
SLACK_APP_TOKEN=xapp-your-app-token-here

# Channel IDs — right-click channel in Slack → View channel details → scroll to bottom
SLACK_CHANNEL_SPRINT_MAIN=C_SPRINT_MAIN_ID_HERE
SLACK_CHANNEL_AGENT_CODER=C_AGENT_CODER_ID_HERE
SLACK_CHANNEL_AGENT_LOG=C_AGENT_LOG_ID_HERE
SLACK_CHANNEL_CI_CD=C_CI_CD_ID_HERE
SLACK_CHANNEL_HUMAN_REVIEW=C_HUMAN_REVIEW_ID_HERE

# Optional
GEMINI_API_KEY=your_gemini_key_here
